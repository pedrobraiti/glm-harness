.env
.venv/
__pycache__/
*.pyc
node_modules/
.DS_Store
.claude/.last-stop-signature

# Home do glm: só a identidade e settings são versionados; o resto é estado de runtime
glm-home/*
!glm-home/CLAUDE.md
!glm-home/settings.json
!glm-home/commands/
!glm-home/skills/
!glm-home/agents/
!glm-home/rules/
!glm-home/hooks/
glm-home/hooks/notifications.log

# Memórias PESSOAIS ficam fora do GitHub (a estrutura é recriada pelo launcher no primeiro uso)
glm-home/memory/
glm-home/skills/vizier/memory/

# Logs de runtime do limiter
logs/

# Binários vendorados do Claude Code (231MB) — reconstruíveis com npm install --prefix vendor + patch
vendor/
